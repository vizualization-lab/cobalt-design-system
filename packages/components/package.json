{
  "name": "@cobalt/components",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Cobalt Design System Web Components",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "custom-elements.json"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./app-shell": {
      "import": "./dist/components/app-shell/co-app-shell.js",
      "types": "./dist/components/app-shell/co-app-shell.d.ts"
    },
    "./input-pill": {
      "import": "./dist/components/input-pill/co-input-pill.js",
      "types": "./dist/components/input-pill/co-input-pill.d.ts"
    },
    "./banner": {
      "import": "./dist/components/banner/co-banner.js",
      "types": "./dist/components/banner/co-banner.d.ts"
    },
    "./card": {
      "import": "./dist/components/card/co-card.js",
      "types": "./dist/components/card/co-card.d.ts"
    },
    "./button": {
      "import": "./dist/components/button/co-button.js",
      "types": "./dist/components/button/co-button.d.ts"
    },
    "./nav-rail-item": {
      "import": "./dist/components/nav-rail-item/co-nav-rail-item.js",
      "types": "./dist/components/nav-rail-item/co-nav-rail-item.d.ts"
    },
    "./checkbox": {
      "import": "./dist/components/checkbox/co-checkbox.js",
      "types": "./dist/components/checkbox/co-checkbox.d.ts"
    },
    "./checkbox-group": {
      "import": "./dist/components/checkbox-group/co-checkbox-group.js",
      "types": "./dist/components/checkbox-group/co-checkbox-group.d.ts"
    },
    "./checkbox-indeterminate": {
      "import": "./dist/components/checkbox-indeterminate/co-checkbox-indeterminate.js",
      "types": "./dist/components/checkbox-indeterminate/co-checkbox-indeterminate.d.ts"
    },
    "./button-icon": {
      "import": "./dist/components/button-icon/co-button-icon.js",
      "types": "./dist/components/button-icon/co-button-icon.d.ts"
    },
    "./combobox": {
      "import": "./dist/components/combobox/co-combobox.js",
      "types": "./dist/components/combobox/co-combobox.d.ts"
    },
    "./form": {
      "import": "./dist/components/form/co-form.js",
      "types": "./dist/components/form/co-form.d.ts"
    },
    "./validation": {
      "import": "./dist/validation.js",
      "types": "./dist/validation.d.ts"
    },
    "./icon": {
      "import": "./dist/components/icon/co-icon.js",
      "types": "./dist/components/icon/co-icon.d.ts"
    },
    "./input": {
      "import": "./dist/components/input/co-input.js",
      "types": "./dist/components/input/co-input.d.ts"
    },
    "./label": {
      "import": "./dist/components/label/co-label.js",
      "types": "./dist/components/label/co-label.d.ts"
    },
    "./nav-header-bar": {
      "import": "./dist/components/nav-header-bar/co-nav-header-bar.js",
      "types": "./dist/components/nav-header-bar/co-nav-header-bar.d.ts"
    },
    "./nav-drawer": {
      "import": "./dist/components/nav-drawer/co-nav-drawer.js",
      "types": "./dist/components/nav-drawer/co-nav-drawer.d.ts"
    },
    "./nav-drawer-item": {
      "import": "./dist/components/nav-drawer-item/co-nav-drawer-item.js",
      "types": "./dist/components/nav-drawer-item/co-nav-drawer-item.d.ts"
    },
    "./nav-separator": {
      "import": "./dist/components/nav-separator/co-nav-separator.js",
      "types": "./dist/components/nav-separator/co-nav-separator.d.ts"
    },
    "./listbox": {
      "import": "./dist/components/listbox/co-listbox.js",
      "types": "./dist/components/listbox/co-listbox.d.ts"
    },
    "./radio": {
      "import": "./dist/components/radio/co-radio.js",
      "types": "./dist/components/radio/co-radio.d.ts"
    },
    "./radio-group": {
      "import": "./dist/components/radio-group/co-radio-group.js",
      "types": "./dist/components/radio-group/co-radio-group.d.ts"
    },
    "./nav-rail-bar": {
      "import": "./dist/components/nav-rail-bar/co-nav-rail-bar.js",
      "types": "./dist/components/nav-rail-bar/co-nav-rail-bar.d.ts"
    },
    "./option": {
      "import": "./dist/components/option/co-option.js",
      "types": "./dist/components/option/co-option.d.ts"
    },
    "./select": {
      "import": "./dist/components/select/co-select.js",
      "types": "./dist/components/select/co-select.d.ts"
    },
    "./textarea": {
      "import": "./dist/components/textarea/co-textarea.js",
      "types": "./dist/components/textarea/co-textarea.d.ts"
    }
  },
  "scripts": {
    "generate-styles": "node scripts/generate-styles.js",
    "generate-styles:watch": "node scripts/generate-styles.js --watch",
    "generate-styles:check": "node scripts/generate-styles.js --check",
    "build": "npm run generate-styles && tsc -p tsconfig.test.json && npm run analyze",
    "analyze": "cem analyze --litelement --globs 'src/**/*.ts'",
    "test": "wtr",
    "test:watch": "wtr --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cobalt/icons": "workspace:*",
    "@cobalt/tokens": "workspace:*",
    "@lion/ui": "^0.15.0",
    "autosize": "^6.0.1",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.0",
    "@open-wc/testing": "^4.0.0",
    "@types/mocha": "^10.0.10",
    "@web/test-runner": "^0.19.0",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-playwright": "^0.11.0",
    "axe-core": "^4.10.0",
    "typescript": "~5.6.0"
  },
  "customElements": "custom-elements.json",
  "license": "MIT"
}
