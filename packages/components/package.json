{
  "name": "@cobalt/components",
  "version": "0.0.1",
  "description": "Cobalt Design System Web Components",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "custom-elements.json"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./button": {
      "import": "./dist/components/button/co-button.js",
      "types": "./dist/components/button/co-button.d.ts"
    },
    "./icon": {
      "import": "./dist/components/icon/co-icon.js",
      "types": "./dist/components/icon/co-icon.d.ts"
    }
  },
  "scripts": {
    "generate-styles": "node scripts/generate-styles.js",
    "generate-styles:watch": "node scripts/generate-styles.js --watch",
    "generate-styles:check": "node scripts/generate-styles.js --check",
    "build": "npm run generate-styles && tsc -p tsconfig.test.json && npm run analyze",
    "analyze": "cem analyze --litelement --globs 'src/**/*.ts'",
    "test": "wtr",
    "test:watch": "wtr --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cobalt/icons": "workspace:*",
    "@cobalt/tokens": "workspace:*",
    "@lion/ui": "^0.15.0",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.0",
    "@open-wc/testing": "^4.0.0",
    "@types/mocha": "^10.0.10",
    "@web/test-runner": "^0.19.0",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-playwright": "^0.11.0",
    "axe-core": "^4.10.0",
    "typescript": "~5.6.0"
  },
  "customElements": "custom-elements.json",
  "license": "MIT"
}
