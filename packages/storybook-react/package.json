{
  "name": "@cobalt/storybook-react",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Storybook runner for Cobalt React wrappers",
  "scripts": {
    "storybook": "storybook dev -p 6102 --ci --exact-port --no-open",
    "build-storybook": "storybook build -o dist",
    "build-storybook:hub": "storybook build -o ../storybook-hub/dist/react"
  },
  "dependencies": {
    "@cobalt/react": "workspace:*",
    "@cobalt/storybook-fixtures": "workspace:*",
    "@cobalt/tokens": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@vitejs/plugin-react": "^5.2.0",
    "storybook": "^10.3.5",
    "vite": "^6.3.0"
  }
}
