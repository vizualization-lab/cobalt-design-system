{
  "name": "@cobalt/storybook-vue",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Storybook runner for Cobalt Vue wrappers",
  "scripts": {
    "storybook": "storybook dev -p 6103 --ci --exact-port --no-open",
    "build-storybook": "storybook build -o dist",
    "build-storybook:hub": "storybook build -o ../storybook-hub/dist/vue"
  },
  "dependencies": {
    "@cobalt/storybook-fixtures": "workspace:*",
    "@cobalt/tokens": "workspace:*",
    "@cobalt/vue": "workspace:*",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "storybook": "^10.3.5",
    "vite": "^6.3.0"
  }
}
