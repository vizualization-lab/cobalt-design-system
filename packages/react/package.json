{
  "name": "@cobalt/react",
  "version": "0.0.1",
  "description": "React wrappers for Cobalt Design System",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./button": {
      "import": "./dist/components/button.js",
      "types": "./dist/components/button.d.ts"
    },
    "./form": {
      "import": "./dist/components/form.js",
      "types": "./dist/components/form.d.ts"
    },
    "./icon": {
      "import": "./dist/components/icon.js",
      "types": "./dist/components/icon.d.ts"
    },
    "./input": {
      "import": "./dist/components/input.js",
      "types": "./dist/components/input.d.ts"
    },
    "./listbox": {
      "import": "./dist/components/listbox.js",
      "types": "./dist/components/listbox.d.ts"
    },
    "./option": {
      "import": "./dist/components/option.js",
      "types": "./dist/components/option.d.ts"
    },
    "./textarea": {
      "import": "./dist/components/textarea.js",
      "types": "./dist/components/textarea.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cobalt/components": "workspace:*",
    "@lit/react": "^1.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "~5.6.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
