{
  "name": "@cobalt/tokens",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Design tokens for the Cobalt Design System",
  "main": "dist/js/tokens.js",
  "types": "dist/js/tokens.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/js/tokens.js",
      "types": "./dist/js/tokens.d.ts"
    },
    "./css": "./dist/css/tokens.css",
    "./css/base": "./dist/css/base.css",
    "./css/dark": "./dist/css/tokens-dark.css",
    "./theme": "./dist/js/theme.js",
    "./themes/*": "./dist/css/themes/*.css",
    "./css/themes/*": "./dist/css/themes/tokens-*.css",
    "./css/fonts": "./dist/css/fonts.css",
    "./css/fonts-international": "./dist/css/fonts-international.css",
    "./css/utilities": "./dist/css/utilities.css",
    "./scss": {
      "sass": "./dist/scss/index.scss",
      "default": "./dist/scss/index.scss"
    },
    "./scss/css": {
      "sass": "./dist/scss/css.scss",
      "default": "./dist/scss/css.scss"
    },
    "./scss/css/dark": {
      "sass": "./dist/scss/css/dark.scss",
      "default": "./dist/scss/css/dark.scss"
    },
    "./scss/themes/*": {
      "sass": "./dist/scss/themes/*.scss",
      "default": "./dist/scss/themes/*.scss"
    },
    "./scss/css/themes/*": {
      "sass": "./dist/scss/css/themes/*.scss",
      "default": "./dist/scss/css/themes/*.scss"
    },
    "./json": "./dist/tokens.json",
    "./dtcg": "./dist/tokens-dtcg.json",
    "./tailwind": {
      "import": "./dist/tailwind/preset.js",
      "types": "./dist/tailwind/preset.d.ts"
    },
    "./tailwind/css": "./dist/tailwind/theme.css"
  },
  "scripts": {
    "build": "node config.js",
    "test": "pnpm run build && pnpm run test:scss",
    "test:scss": "node scripts/validate-scss.js",
    "validate": "node scripts/validate-tokens.js",
    "merge-tokens": "node scripts/merge-tokens.js",
    "export-dtcg": "node scripts/export-dtcg.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/noto-sans": "^5.2.10"
  },
  "devDependencies": {
    "sass": "^1.99.0",
    "style-dictionary": "^4.0.0"
  },
  "license": "MIT"
}
