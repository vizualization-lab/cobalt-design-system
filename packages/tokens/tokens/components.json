{
  "co": {
    "component": {
      "avatar": {
        "size": {
          "sm": {
            "$type": "dimension",
            "$value": "24px",
            "$description": "Compact avatar size for dense layouts, tables, and inline references."
          },
          "md": {
            "$type": "dimension",
            "$value": "32px",
            "$description": "Default avatar size for navigation, lists, and standard UI surfaces."
          },
          "lg": {
            "$type": "dimension",
            "$value": "38px",
            "$description": "Large avatar size for profile headers and prominent identity surfaces."
          }
        }
      },
      "card": {
        "padding": {
          "$type": "dimension",
          "$value": "{co.space.inset.lg}",
          "$description": "Internal padding for the card."
        },
        "gap": {
          "$type": "dimension",
          "$value": "{co.space.gap.sm}",
          "$description": "Gap between card sections."
        },
        "radius": {
          "$type": "dimension",
          "$value": "{co.shape.radius.lg}",
          "$description": "Corner radius for the card."
        },
        "background": {
          "$type": "color",
          "$value": "{co.color.surface.raised}",
          "$description": "Card background color."
        },
        "shadow": {
          "$type": "shadow",
          "$value": "{co.elevation.shadow.sm}",
          "$description": "Card elevation shadow."
        }
      },
      "banner": {
        "height": {
          "$type": "dimension",
          "$value": "44px",
          "$description": "Minimum height for the banner."
        },
        "padding": {
          "$type": "dimension",
          "$value": "{co.space.1}",
          "$description": "Internal padding for the banner."
        },
        "background": {
          "$type": "color",
          "$value": "{co.color.surface.raised}",
          "$description": "Banner background color."
        },
        "foreground": {
          "$type": "color",
          "$value": "{co.color.text.default}",
          "$description": "Banner text color."
        },
        "title": {
          "weight": {
            "$type": "fontWeight",
            "$value": "{co.font.weight.medium}",
            "$description": "Font weight for the banner title."
          }
        }
      },
      "nav": {
        "rail": {
          "bar": {
            "width": {
              "$type": "dimension",
              "$value": "116px",
              "$description": "Default width for compact vertical navigation rails."
            },
            "width-max": {
              "$type": "dimension",
              "$value": "140px",
              "$description": "Max width for compact vertical navigation rails."
            },
            "padding": {
              "x": {
                "$type": "dimension",
                "$value": "{co.space.2}",
                "$description": "Horizontal inset padding applied around nav rail items."
              },
              "y": {
                "$type": "dimension",
                "$value": "{co.space.3}",
                "$description": "Vertical inset padding applied around nav rail items."
              }
            },
            "gap": {
              "$type": "dimension",
              "$value": "{co.space.2}",
              "$description": "Vertical gap between nav rail items."
            },
            "radius": {
              "$type": "dimension",
              "$value": "{co.shape.radius.lg}",
              "$description": "Outer corner radius for the nav rail container."
            },
            "background": {
              "$type": "color",
              "$value": "{co.color.surface.bold}",
              "$description": "Container background for nav rail bars in both light and dark themes."
            }
          },
          "item": {
            "padding": {
              "x": {
                "$type": "dimension",
                "$value": "{co.space.3}",
                "$description": "Horizontal padding for each nav rail item."
              },
              "y": {
                "$type": "dimension",
                "$value": "{co.space.2}",
                "$description": "Vertical padding for each nav rail item."
              }
            },
            "gap": {
              "$type": "dimension",
              "$value": "{co.space.1}",
              "$description": "Space between the icon and label within a nav rail item."
            },
            "radius": {
              "$type": "dimension",
              "$value": "{co.shape.radius.sm}",
              "$description": "Corner radius for nav rail item surfaces."
            },
            "icon": {
              "size": {
                "$type": "dimension",
                "$value": "22px",
                "$description": "Default icon size for compact nav rail destinations."
              }
            },
            "background": {
              "default": {
                "$type": "color",
                "$value": "{co.color.interactive.subtle.default}",
                "$description": "Resting surface for nav rail items."
              },
              "hover": {
                "$type": "color",
                "$value": "color-mix(in srgb, {co.color.interactive.primary.default} 8%, transparent)",
                "$description": "Hover surface for nav rail items."
              },
              "active": {
                "$type": "color",
                "$value": "color-mix(in srgb, {co.color.interactive.primary.default} 20%, transparent)",
                "$description": "Pressed surface for nav rail items."
              },
              "selected": {
                "$type": "color",
                "$value": "color-mix(in srgb, {co.color.interactive.primary.default} 12%, transparent)",
                "$description": "Selected surface for the current nav rail destination."
              }
            },
            "foreground": {
              "default": {
                "$type": "color",
                "$value": "{co.color.text.secondary}",
                "$description": "Default text and icon color for nav rail items."
              },
              "hover": {
                "$type": "color",
                "$value": "{co.color.text.link}",
                "$description": "Hover text and icon color for nav rail items."
              },
              "active": {
                "$type": "color",
                "$value": "{co.color.text.link}",
                "$description": "Pressed text and icon color for nav rail items."
              },
              "selected": {
                "$type": "color",
                "$value": "{co.color.text.link}",
                "$description": "Selected text and icon color for the current nav rail destination."
              }
            },
            "focus": {
              "ring": {
                "$type": "color",
                "$value": "{co.color.border.focus}",
                "$description": "Focus ring color for nav rail item keyboard focus."
              }
            }
          }
        },
        "drawer": {
          "item": {
            "background": {
              "hover": {
                "$type": "color",
                "$value": "color-mix(in srgb, {co.color.interactive.primary.default} 8%, transparent)",
                "$description": "Hover surface for nav drawer items."
              },
              "active": {
                "$type": "color",
                "$value": "color-mix(in srgb, {co.color.interactive.primary.default} 20%, transparent)",
                "$description": "Pressed surface for nav drawer items."
              },
              "selected": {
                "$type": "color",
                "$value": "color-mix(in srgb, {co.color.interactive.primary.default} 12%, transparent)",
                "$description": "Selected surface for the current nav drawer destination."
              }
            },
            "foreground": {
              "hover": {
                "$type": "color",
                "$value": "{co.color.text.link}",
                "$description": "Hover text and icon color for nav drawer items."
              },
              "active": {
                "$type": "color",
                "$value": "{co.color.text.link}",
                "$description": "Pressed text and icon color for nav drawer items."
              },
              "selected": {
                "$type": "color",
                "$value": "{co.color.text.link}",
                "$description": "Selected text and icon color for the current nav drawer destination."
              }
            },
            "focus": {
              "ring": {
                "$type": "color",
                "$value": "{co.color.border.focus}",
                "$description": "Focus ring color for nav drawer item keyboard focus."
              }
            }
          }
        }
      }
    }
  }
}
