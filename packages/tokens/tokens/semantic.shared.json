      },
      "title": {
        "weight": { "$value": "{co.font.weight.regular}", "$type": "fontWeight" },
        "size": { "$value": "{co.font.size.2xl}", "$type": "dimension" },
        "tracking": { "$value": "{co.font.tracking.tight}", "$type": "dimension" },
        "line-height": { "$value": "{co.font.line-height.tight}", "$type": "number" }
      },
      "subtitle": {
        "weight": { "$value": "{co.font.weight.medium}", "$type": "fontWeight" },
        "size": { "$value": "{co.font.size.xl}", "$type": "dimension" },
        "tracking": { "$value": "{co.font.tracking.tight}", "$type": "dimension" },
        "line-height": { "$value": "{co.font.line-height.tight}", "$type": "number" }
      },
      "eyebrow": {
        "weight": { "$value": "{co.font.weight.medium}", "$type": "fontWeight" },
