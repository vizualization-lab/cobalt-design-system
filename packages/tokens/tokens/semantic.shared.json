        "line-height": { "$value": "{co.font.line-height.tight}", "$type": "number" }
      },
      "body-lg": {
        "weight": { "$value": "{co.font.weight.regular}", "$type": "fontWeight" },
        "size": { "$value": "{co.font.size.lg}", "$type": "dimension" },
        "tracking": { "$value": "{co.font.tracking.normal}", "$type": "dimension" },
        "line-height": { "$value": "{co.font.line-height.normal}", "$type": "number" }
      },
      "body": {
        "weight": { "$value": "{co.font.weight.regular}", "$type": "fontWeight" },
        "size": { "$value": "{co.font.size.md}", "$type": "dimension" },
        "tracking": { "$value": "{co.font.tracking.normal}", "$type": "dimension" },
        "line-height": { "$value": "{co.font.line-height.normal}", "$type": "number" }
      },
      "body-sm": {
        "weight": { "$value": "{co.font.weight.regular}", "$type": "fontWeight" },
        "size": { "$value": "{co.font.size.sm}", "$type": "dimension" },
