{
  "co": {
    "focus": {
      "ring": {
        "width": { "$value": "{co.shape.border-width.thick}", "$type": "dimension" },
        "offset": { "$value": "{co.space.1}", "$type": "dimension" }
      }
    },
    "control": {
      "radius": { "$value": "{co.shape.radius.sm}", "$type": "dimension" },
      "height": {
        "sm": { "$value": "32px", "$type": "dimension" },
        "md": { "$value": "40px", "$type": "dimension" },
        "lg": { "$value": "48px", "$type": "dimension" }
      }
    },
    "layout": {
      "content": {
        "max-width": {
          "sm": { "$value": "{co.breakpoint.sm}", "$type": "dimension" },
          "md": { "$value": "{co.breakpoint.md}", "$type": "dimension" },
          "lg": { "$value": "{co.breakpoint.lg}", "$type": "dimension" },
          "xl": { "$value": "{co.breakpoint.xl}", "$type": "dimension" }
        }
      }
    },
    "typography": {
      "display": {
        "weight": { "$value": "{co.font.weight.regular}", "$type": "fontWeight" },
        "size": { "$value": "{co.font.size.5xl}", "$type": "dimension" },
        "tracking": { "$value": "{co.font.tracking.tighter}", "$type": "dimension" },
        "line-height": { "$value": "{co.font.line-height.display}", "$type": "number" }
      },
      "heading": {
        "weight": { "$value": "{co.font.weight.regular}", "$type": "fontWeight" },
