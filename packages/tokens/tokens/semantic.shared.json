        },
        "line-height": {
          "$type": "number",
          "$value": "{co.font.line-height.normal}"
        }
      },
      "label": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{co.font.weight.medium}"
        },
        "size": {
          "$type": "dimension",
          "$value": "{co.font.size.sm}"
        },
        "tracking": {
          "$type": "dimension",
          "$value": "{co.font.tracking.normal}"
        },
        "line-height": {
          "$type": "number",
          "$value": "{co.font.line-height.tight}"
        }
      },
      "caption": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{co.font.weight.regular}"
        },
        "size": {
          "$type": "dimension",
          "$value": "{co.font.size.xs}"
        },
        "tracking": {
          "$type": "dimension",
          "$value": "{co.font.tracking.normal}"
        },
        "line-height": {
          "$type": "number",
