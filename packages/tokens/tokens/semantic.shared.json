          "$type": "dimension",
          "$value": "{co.font.size.4xl}"
        },
        "tracking": {
          "$type": "dimension",
          "$value": "{co.font.tracking.tight}"
        },
        "line-height": {
          "$type": "number",
          "$value": "{co.font.line-height.display}"
        }
      },
      "title": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{co.font.weight.regular}"
