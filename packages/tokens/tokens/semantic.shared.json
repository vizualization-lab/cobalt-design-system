{
  "co": {
    "focus": {
      "ring": {
        "width": {
          "$type": "dimension",
          "$value": "{co.shape.border-width.thick}"
        },
        "offset": {
          "$type": "dimension",
          "$value": "{co.space.1}"
        }
      }
    },
    "control": {
      "radius": {
        "$type": "dimension",
        "$value": "{co.shape.radius.sm}"
      },
      "height": {
        "sm": {
          "$type": "dimension",
          "$value": "32px"
        },
        "md": {
          "$type": "dimension",
          "$value": "40px"
        },
        "lg": {
          "$type": "dimension",
          "$value": "48px"
        }
      }
    },
    "layout": {
      "content": {
        "max-width": {
          "sm": {
            "$type": "dimension",
            "$value": "{co.breakpoint.sm}"
          },
          "md": {
            "$type": "dimension",
            "$value": "{co.breakpoint.md}"
          },
          "lg": {
            "$type": "dimension",
            "$value": "{co.breakpoint.lg}"
          },
          "xl": {
            "$type": "dimension",
            "$value": "{co.breakpoint.xl}"
          }
        }
      }
    },
    "typography": {
      "display": {
        "weight": {
          "$type": "fontWeight",
          "$value": "{co.font.weight.regular}"
        },
        "size": {
          "$type": "dimension",
          "$value": "{co.font.size.5xl}"
        },
        "tracking": {
          "$type": "dimension",
          "$value": "{co.font.tracking.tighter}"
        },
        "line-height": {
          "$type": "number",
          "$value": "{co.font.line-height.display}"
        }
      },
