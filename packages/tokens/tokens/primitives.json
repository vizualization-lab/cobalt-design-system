        },
        "sm": {
          "$type": "dimension",
          "$value": "20px",
          "$description": "Small icon size — buttons, form controls"
        },
        "md": {
          "$type": "dimension",
          "$value": "24px",
          "$description": "Medium icon size — standalone icons, navigation"
        },
        "lg": {
          "$type": "dimension",
          "$value": "32px",
          "$description": "Large icon size — empty states, feature highlights"
        },
        "xl": {
          "$type": "dimension",
          "$value": "48px",
          "$description": "Extra large icon size — hero sections, prominent actions"
        }
      }
