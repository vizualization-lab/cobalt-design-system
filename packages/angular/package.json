{
  "name": "@cobalt/angular",
  "version": "0.0.1",
  "description": "Angular wrappers for Cobalt Design System",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./button": {
      "import": "./dist/components/button.js",
      "types": "./dist/components/button.d.ts"
    },
    "./button-icon": {
      "import": "./dist/components/button-icon.js",
      "types": "./dist/components/button-icon.d.ts"
    },
    "./combobox": {
      "import": "./dist/components/combobox.js",
      "types": "./dist/components/combobox.d.ts"
    },
    "./form": {
      "import": "./dist/components/form.js",
      "types": "./dist/components/form.d.ts"
    },
    "./icon": {
      "import": "./dist/components/icon.js",
      "types": "./dist/components/icon.d.ts"
    },
    "./input": {
      "import": "./dist/components/input.js",
      "types": "./dist/components/input.d.ts"
    },
    "./listbox": {
      "import": "./dist/components/listbox.js",
      "types": "./dist/components/listbox.d.ts"
    },
    "./option": {
      "import": "./dist/components/option.js",
      "types": "./dist/components/option.d.ts"
    },
    "./select": {
      "import": "./dist/components/select.js",
      "types": "./dist/components/select.d.ts"
    },
    "./textarea": {
      "import": "./dist/components/textarea.js",
      "types": "./dist/components/textarea.d.ts"
    }
  },
  "scripts": {
    "build": "ngc",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cobalt/components": "workspace:*"
  },
  "peerDependencies": {
    "@angular/common": "^17.3.0 || ^18.0.0 || ^19.0.0 || ^20.0.0 || ^21.0.0",
    "@angular/core": "^17.3.0 || ^18.0.0 || ^19.0.0 || ^20.0.0 || ^21.0.0"
  },
  "devDependencies": {
    "@angular/common": "^19.2.19",
    "@angular/compiler": "^19.2.20",
    "@angular/compiler-cli": "^19.2.20",
    "@angular/core": "^19.2.19",
    "@angular/platform-browser": "^19.2.20",
    "@angular/platform-browser-dynamic": "^19.2.20",
    "jsdom": "^25.0.0",
    "rxjs": "^7.8.0",
    "typescript": "~5.6.0",
    "vitest": "^3.0.0",
    "zone.js": "^0.15.0"
  },
  "license": "MIT"
}
