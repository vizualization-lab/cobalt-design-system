{
  "name": "@cobalt/angular",
  "version": "0.0.1",
  "description": "Angular wrappers for Cobalt Design System",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./button": {
      "import": "./dist/components/button.js",
      "types": "./dist/components/button.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cobalt/components": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "@angular/common": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@angular/core": "^19.0.0",
    "@angular/common": "^19.0.0",
    "rxjs": "^7.8.0",
    "typescript": "~5.6.0",
    "zone.js": "^0.15.0"
  },
  "license": "MIT"
}
