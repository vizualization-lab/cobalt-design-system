{
  "name": "cobalt-design-system",
  "version": "0.0.0",
  "private": true,
  "description": "Cobalt Design System — a design token driven web component library built with Lit and TypeScript.",
  "scripts": {
    "clean": "pnpm -r --stream clean && rm -rf packages/docs/.vitepress/cache",
    "build": "pnpm -r --stream build",
    "rebuild": "pnpm clean && pnpm build",
    "dev": "pnpm --filter @cobalt/docs dev",
    "workbench": "pnpm --filter @cobalt/workbench dev",
    "storybook:prepare": "pnpm --filter @cobalt/tokens build && pnpm --filter @cobalt/icons build",
    "storybook:controls:generate": "pnpm --filter @cobalt/components analyze && pnpm --filter @cobalt/storybook-fixtures generate-controls",
    "storybook:controls:check": "pnpm --filter @cobalt/storybook-fixtures check-controls",
    "storybook:stories:generate": "pnpm --filter @cobalt/storybook-fixtures generate-stories",
    "storybook:stories:check": "pnpm --filter @cobalt/storybook-fixtures check-stories",
    "storybook:generate": "pnpm storybook:controls:generate && pnpm storybook:stories:generate",
    "storybook:check": "pnpm storybook:controls:check && pnpm storybook:stories:check",
    "storybook:hub": "pnpm storybook:dev",
    "storybook:hub:only": "pnpm storybook:prepare && pnpm --filter @cobalt/storybook-hub dev",
    "storybook:web-components": "pnpm storybook:prepare && pnpm --filter @cobalt/storybook-web-components storybook",
    "storybook:react": "pnpm storybook:prepare && pnpm --filter @cobalt/storybook-react storybook",
    "storybook:vue": "pnpm storybook:prepare && pnpm --filter @cobalt/storybook-vue storybook",
    "storybook:angular": "pnpm storybook:prepare && pnpm --filter @cobalt/storybook-angular storybook",
    "storybook:dev": "pnpm storybook:prepare && concurrently -k -n hub,web,react,vue,angular -c auto \"pnpm --filter @cobalt/storybook-hub dev\" \"pnpm --filter @cobalt/storybook-web-components storybook\" \"pnpm --filter @cobalt/storybook-react storybook\" \"pnpm --filter @cobalt/storybook-vue storybook\" \"pnpm --filter @cobalt/storybook-angular storybook\"",
    "storybook:build": "pnpm storybook:prepare && pnpm storybook:check && pnpm --filter @cobalt/storybook-hub build && pnpm --filter @cobalt/storybook-web-components build-storybook:hub && pnpm --filter @cobalt/storybook-react build-storybook:hub && pnpm --filter @cobalt/storybook-vue build-storybook:hub && pnpm --filter @cobalt/storybook-angular build-storybook:hub",
    "test": "pnpm -r --stream test",
    "test:watch": "pnpm --filter @cobalt/components test:watch",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack:local": "bash scripts/pack-local.sh",
    "changeset": "changeset",
    "version:bump": "changeset version && node scripts/aggregate-changelog.js",
    "version:check": "changeset status --verbose",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.styles.css": "node packages/components/scripts/generate-styles.js && git add '*.styles.ts'",
    "*.{ts,js,json,css,md,vue,html}": "prettier --write"
  },
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-wc": "^3.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1"
  }
}
